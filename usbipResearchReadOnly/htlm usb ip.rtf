  <tr><td>USB Audio (Class 1)</td><td><span class="chk">\uc0\u10003  Good</span></td><td><span class="chk">\u10003  Good</span></td><td><span class="pmk">\u9888 \u65039  Variable</span></td><td><span class="xmk">\u10007  Unreliable</span></td><td><span class="xmk">\u10007  Fails</span></td></tr>\
