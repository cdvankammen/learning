  <tr><td>USB Webcam (YUYV 1080p)</td><td><span class="xmk">\uc0\u10007  Fails</span></td><td><span class="xmk">\u10007  Fails</span></td><td><span class="xmk">\u10007  Fails</span></td><td><span class="xmk">\u10007  Fails</span></td><td><span class="xmk">\u10007  Fails</span></td></tr>\
